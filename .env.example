# NeonDB
DATABASE_URL="postgresql://user:pass@host/dbname?sslmode=require"

# NextAuth (Auth.js v5)
AUTH_SECRET="your-secret"
NEXTAUTH_SECRET="your-secret"
# Local: http://localhost:3000 | Production with SSL: https://lmsclasses.com (must match browser URL)
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"
# Production (SSL): NEXTAUTH_URL="https://lmsclasses.com"

# Temporary: set on Hostinger to reset a user password via POST /api/bootstrap/reset-password
# Remove after use. Body: { "email": "...", "newPassword": "...", "secret": "..." }
# BOOTSTRAP_SECRET="change-me-then-remove"

# Email — Hostinger (recommended for info@lmsclasses.com)
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="info@lmsclasses.com"
SMTP_PASS="your-email-account-password"
MAIL_FROM="LMS Platform <info@lmsclasses.com>"

# Optional fallback (if SMTP not set)
# RESEND_API_KEY="re_..."
# RESEND_FROM_EMAIL="LMS Platform <info@lmsclasses.com>"

# Razorpay (required) — https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID="rzp_test_xxxxxxxx"
RAZORPAY_KEY_SECRET="your_secret_key"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxxxxxx"
# Webhook secret from Razorpay Dashboard → Webhooks (URL: https://lmsclasses.com/api/payments/webhook)
RAZORPAY_WEBHOOK_SECRET="your_webhook_secret"

# App
NEXT_PUBLIC_APP_URL="https://lmsclasses.com"
NEXT_PUBLIC_APP_NAME="LMS Platform"

# Uploads — Hostinger: store files in public_html so they survive redeploys and are served as static files.
# Create the folder in File Manager, then set the absolute path (adjust USER and domain):
# UPLOADS_DIR="/home/USER/domains/lmsclasses.com/public_html/uploads"
# Subfolders created automatically: course-thumbnails, hr-logos, resumes
# Public URLs: https://lmsclasses.com/uploads/course-thumbnails/...
# Local dev: omit UPLOADS_DIR (defaults to ./public/uploads)
