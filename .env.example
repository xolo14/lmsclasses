# NeonDB
DATABASE_URL="postgresql://user:pass@host/dbname?sslmode=require"

# NextAuth (Auth.js v5)
AUTH_SECRET="your-secret"
NEXTAUTH_SECRET="your-secret"
# Local: http://localhost:3000 | Production: https://lmsclasses.com (must match browser URL)
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Temporary: set on Hostinger to reset a user password via POST /api/bootstrap/reset-password
# Remove after use. Body: { "email": "...", "newPassword": "...", "secret": "..." }
# BOOTSTRAP_SECRET="change-me-then-remove"

# Resend (email)
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="LMS Platform <onboarding@resend.dev>"

# Razorpay — https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID="rzp_test_xxxxxxxx"
RAZORPAY_KEY_SECRET="your_secret_key"
# Optional if RAZORPAY_KEY_ID is set (checkout key is returned from API)
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxxxxxx"
# Webhook secret from Razorpay Dashboard → Webhooks (URL: https://lmsclasses.com/api/payments/webhook)
RAZORPAY_WEBHOOK_SECRET="your_webhook_secret"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="LMS Platform"
