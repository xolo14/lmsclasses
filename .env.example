# NeonDB
DATABASE_URL="postgresql://user:pass@host/dbname?sslmode=require"

# NextAuth (Auth.js v5)
AUTH_SECRET="your-secret"
NEXTAUTH_SECRET="your-secret"
# Local: http://localhost:3000 | Production: https://lmsclasses.com (must match browser URL)
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Temporary: set on Hostinger to reset a user password via POST /api/bootstrap/reset-password
# Remove after use. Body: { "email": "...", "newPassword": "...", "secret": "..." }
# BOOTSTRAP_SECRET="change-me-then-remove"

# Resend (email)
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="LMS Platform <onboarding@resend.dev>"

# Razorpay
RAZORPAY_KEY_ID="rzp_test_..."
RAZORPAY_KEY_SECRET="..."
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_..."

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="LMS Platform"
